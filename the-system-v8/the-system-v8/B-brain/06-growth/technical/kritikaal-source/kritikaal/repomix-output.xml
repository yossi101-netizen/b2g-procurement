                fill: "#ffffff",
                stroke: "#000000",
                strokeWidth: 4,
                paintOrder: "stroke",
                letterSpacing: "2px",
                textTransform: "uppercase",
              }}
            >
              CHINA
            </motion.text>
          </Marker>
        </ComposableMap>
      </motion.div>
    </div>
  );
};

export default ChinaFocusMap;
