<file path="src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* Leather-Based Color Palette - 5 Core Colors */
    /* 1. Muted Off-White (Background) */
    --background: 35 25% 95%;
    --foreground: 20 15% 15%;

    /* Card uses warm beige tones */
    --card: 35 20% 92%;
    --card-foreground: 20 15% 15%;

    --popover: 35 25% 95%;
    --popover-foreground: 20 15% 15%;

    /* 2. Saddle Tan - Primary (Action color) */
    --primary: 28 55% 50%;
    --primary-foreground: 35 25% 95%;

    /* 3. Charcoal/Near-Black - Secondary */
    --secondary: 20 12% 18%;
    --secondary-foreground: 35 25% 95%;

    /* Muted tones */
    --muted: 35 18% 88%;
    --muted-foreground: 20 10% 40%;

    /* Accent (Saddle Tan highlight) */
    --accent: 28 50% 55%;
    --accent-foreground: 20 15% 15%;

    --destructive: 0 84% 60%;
    --destructive-foreground: 35 25% 95%;

    --border: 30 15% 82%;
    --input: 30 15% 82%;
    --ring: 28 55% 50%;

    --radius: 0.5rem;

    /* Custom Leather Tokens - 5 Color System */
    /* 1. Deep Leather Brown */
    --deep-leather-brown: 20 45% 22%;
    /* 2. Saddle Tan */
    --saddle-tan: 28 55% 50%;
    /* 3. Warm Beige */
    --warm-beige: 35 30% 90%;
    /* 4. Charcoal (Near-Black) */
    --charcoal: 20 15% 15%;
    /* 5. Muted Off-White */
    --off-white: 35 25% 95%;

    /* Legacy tokens mapped to new system */
    --cream: 35 25% 95%;
    --cognac: 28 55% 50%;
    --cognac-dark: 20 45% 22%;
    --gold: 28 50% 55%;
    --warm-gray: 25 12% 50%;

    /* Sidebar */
    --sidebar-background: 20 15% 15%;
    --sidebar-foreground: 35 25% 95%;
    --sidebar-primary: 28 55% 50%;
    --sidebar-primary-foreground: 35 25% 95%;
    --sidebar-accent: 20 40% 28%;
    --sidebar-accent-foreground: 35 25% 95%;
    --sidebar-border: 20 12% 18%;
    --sidebar-ring: 28 55% 50%;
  }

  .dark {
    --background: 20 15% 10%;
    --foreground: 35 25% 95%;

    --card: 20 12% 14%;
    --card-foreground: 35 25% 95%;

    --popover: 20 15% 10%;
    --popover-foreground: 35 25% 95%;

    --primary: 28 50% 55%;
    --primary-foreground: 20 15% 10%;

    --secondary: 25 12% 22%;
    --secondary-foreground: 35 25% 95%;

    --muted: 20 10% 20%;
    --muted-foreground: 30 15% 60%;

    --accent: 28 50% 55%;
    --accent-foreground: 20 15% 10%;

    --destructive: 0 62% 30%;
    --destructive-foreground: 35 25% 95%;

    --border: 20 10% 22%;
    --input: 20 10% 22%;
    --ring: 28 50% 55%;

    --sidebar-background: 20 15% 8%;
    --sidebar-foreground: 35 25% 95%;
    --sidebar-primary: 28 50% 55%;
    --sidebar-primary-foreground: 20 15% 8%;
    --sidebar-accent: 20 10% 18%;
    --sidebar-accent-foreground: 35 25% 95%;
    --sidebar-border: 20 10% 18%;
    --sidebar-ring: 28 50% 55%;
  }
}

@layer base {
  * {
    @apply border-border;
  }

  body {
    @apply bg-background text-foreground font-serif antialiased;
    font-family: 'Playfair Display', serif;
  }

  /* All text uses serif font */
  p {
    font-family: 'Playfair Display', serif;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Playfair Display', serif;
    @apply font-semibold tracking-tight;
  }
}

@layer utilities {
  .font-serif {
    font-family: 'Playfair Display', serif;
  }

  .font-sans {
    font-family: 'Inter', sans-serif;
  }

  .text-gradient {
    @apply bg-clip-text text-transparent;
    background-image: linear-gradient(135deg, hsl(var(--primary)) 0%, hsl(var(--accent)) 100%);
  }

  .bg-gradient-hero {
    background: linear-gradient(135deg, hsl(var(--charcoal)) 0%, hsl(var(--deep-leather-brown)) 100%);
  }

  .bg-gradient-section {
    background: linear-gradient(180deg, hsl(var(--background)) 0%, hsl(var(--muted)) 100%);
  }

  .bg-gradient-cta {
    background: linear-gradient(135deg, hsl(var(--saddle-tan)) 0%, hsl(var(--deep-leather-brown)) 100%);
  }

  .shadow-luxury {
    box-shadow: 0 25px 50px -12px hsla(var(--charcoal), 0.25);
  }

  .shadow-card {
    box-shadow: 0 10px 40px -10px hsla(var(--charcoal), 0.15);
  }

  .border-gold {
    border-color: hsl(var(--gold));
  }

  /* Leather texture background */
  .bg-leather {
    background: 
      linear-gradient(135deg, #5D4037 0%, #4E342E 50%, #3E2723 100%);
    position: relative;
  }

  .bg-leather::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
  }

  /* Leather stitched navbar */
  .leather-navbar {
    background-color: #5D4037;
    position: relative;
    border-bottom: 3px solid #3E2723;
  }

  .leather-navbar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(109, 76, 65, 0.2) 0%, rgba(93, 64, 55, 0.2) 50%, rgba(78, 52, 46, 0.2) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Top stitch line */
  .leather-navbar::after {
    content: '';
    position: absolute;
    top: 4px;
    left: 20px;
    right: 20px;
    height: 2px;
    background-image: repeating-linear-gradient(
      90deg,
      #D4A574 0px,
      #D4A574 8px,
      transparent 8px,
      transparent 12px
    );
    opacity: 0.7;
  }

  /* Leather stitch box - for CTA buttons */
  .leather-stitch-box {
    position: relative;
    padding: 4px;
    background: transparent;
  }

  .leather-stitch-box::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px dashed #D4A574;
    border-radius: 12px;
    opacity: 0.6;
    pointer-events: none;
  }

  .leather-stitch-box::after {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid #8B5A2B;
    border-radius: 10px;
    opacity: 0.3;
    pointer-events: none;
  }

  /* Bottom stitch effect */
  .leather-stitch-bottom {
    position: relative;
  }

  .leather-stitch-bottom::before {
    content: '';
    position: absolute;
    bottom: 6px;
    left: 20px;
    right: 20px;
    height: 2px;
    background-image: repeating-linear-gradient(
      90deg,
      #D4A574 0px,
      #D4A574 8px,
      transparent 8px,
      transparent 12px
    );
    opacity: 0.7;
  }

  /* Leather patch logo style */
  .leather-logo-patch {
    position: relative;
    background: linear-gradient(145deg, #8B7355 0%, #6B5344 30%, #5D4037 70%, #4A3728 100%);
    border-radius: 8px;
    padding: 8px 16px;
    box-shadow: 
      inset 0 2px 4px rgba(255,255,255,0.1),
      inset 0 -2px 4px rgba(0,0,0,0.2),
      0 4px 8px rgba(0,0,0,0.3),
      0 2px 4px rgba(0,0,0,0.2);
    border: 1px solid #3E2723;
  }

  .leather-logo-patch::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='1.2' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.15;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* Rivet/button decorations */
  .leather-rivet {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, #C9A96E, #8B7355 40%, #5D4037 100%);
    box-shadow: 
      inset 0 1px 2px rgba(255,255,255,0.4),
      0 1px 2px rgba(0,0,0,0.4);
  }

  /* Section leather backgrounds */
  .bg-leather-light {
    background: linear-gradient(180deg, #D7CCC8 0%, #BCAAA4 100%);
    position: relative;
  }

  .bg-leather-light::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.05;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .bg-leather-dark {
    background: linear-gradient(180deg, #3E2723 0%, #2C1810 100%);
    position: relative;
  }

  .bg-leather-dark::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.08;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* Stitched border effect */
  .stitched-border {
    position: relative;
  }

  .stitched-border::after {
    content: '';
    position: absolute;
    inset: 8px;
    border: 2px dashed rgba(212, 165, 116, 0.5);
    border-radius: inherit;
    pointer-events: none;
  }
}

/* Smooth scroll */
html {
  scroll-behavior: smooth;
}

/* ===== ZIPPER SCROLLBAR ===== */

/* Firefox fallback */
html {
  scrollbar-color: #C9A96E #2C1810;
  scrollbar-width: thin;
}

::-webkit-scrollbar {
  width: 22px;
}

/*
  Track: each 22×16 px tile shows one left tooth (upper half) and one right tooth
  (lower half, offset by 8 px) so the two sides interlock when tiled vertically.

  Anatomy of the tile:
    x 0–1    : left leather tape
    x 2–9    : left tooth body  (row 1–7)
    x 10–11  : centre spine
    x 12–19  : right tooth body (row 9–15)
    x 20–21  : right leather tape
*/
::-webkit-scrollbar-track {
  background-color: #2C1810;
  background-image: url("data:image/svg+xml,%3Csvg width='22' height='16' xmlns='http://www.w3.org/2000/svg'%3E%3Crect width='22' height='16' fill='%232C1810'/%3E%3Crect x='0' y='0' width='2' height='16' fill='%233D2015'/%3E%3Crect x='20' y='0' width='2' height='16' fill='%233D2015'/%3E%3Crect x='10' y='0' width='2' height='16' fill='%234A2E1A'/%3E%3Crect x='2' y='1' width='8' height='7' rx='2' fill='%23C9A96E' stroke='%23A07820' stroke-width='0.5'/%3E%3Crect x='3' y='2' width='3' height='2' rx='1' fill='%23F5E0A0' opacity='0.8'/%3E%3Crect x='2' y='8' width='8' height='1' rx='0' fill='%236B4010' opacity='0.5'/%3E%3Crect x='12' y='9' width='8' height='7' rx='2' fill='%23C9A96E' stroke='%23A07820' stroke-width='0.5'/%3E%3Crect x='13' y='10' width='3' height='2' rx='1' fill='%23F5E0A0' opacity='0.8'/%3E%3Crect x='12' y='15' width='8' height='1' rx='0' fill='%236B4010' opacity='0.5'/%3E%3C/svg%3E");
  background-repeat: repeat-y;
  background-size: 22px 16px;
}

/*
  Thumb: a knurled brass slider box.
  - Horizontal grip ridges (repeating-linear-gradient) mimic the knurl
    texture pressed into real metal sliders.
  - Left-to-right metallic gradient gives the convex brass surface look.
  - Asymmetric borders: gold top edge (catching light) / dark bottom edge
    (in shadow) complete the 3-D clamping-jaw illusion.
*/
::-webkit-scrollbar-thumb {
  background:
    /* Horizontal knurl / grip ridges */
    repeating-linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.14) 0px,
