              r: [15, 20, 15],
              fillOpacity: [0.6, 0.8, 0.6],
            }}
            transition={{
              duration: 2.5,
              repeat: Infinity,
              ease: "easeInOut",
            }}
          />

          {/* Core marker */}
          <circle 
            r={9} 
