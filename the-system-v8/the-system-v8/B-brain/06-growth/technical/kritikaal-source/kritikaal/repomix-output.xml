      #C8A050 50%,
      #A98050 68%,
      #4A2508 100%
    );
}

::-webkit-scrollbar-corner {
  background: #2C1810;
}

/* ========== MOBILE RESPONSIVENESS ========== */

/* Base mobile improvements */
@media (max-width: 640px) {
  /* Typography scaling for mobile */
  h1 {
    font-size: 1.875rem !important;
    line-height: 1.2 !important;
  }
  
  h2 {
    font-size: 1.5rem !important;
    line-height: 1.25 !important;
  }
  
  h3 {
    font-size: 1.25rem !important;
  }

  /* Container padding */
  .container {
    padding-left: 1rem !important;
    padding-right: 1rem !important;
  }



  /* Card spacing */
  .grid {
    gap: 1rem !important;
  }

  /* Button sizing for touch */
  button, .btn, [role="button"] {
    min-height: 44px;
    min-width: 44px;
  }

  /* Better tap targets */
  a {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  /* Footer grid mobile */
  footer .grid {
    grid-template-columns: 1fr !important;
    gap: 2rem !important;
  }

  /* Mobile navigation improvements */
  nav .container {
    padding-left: 0.75rem !important;
    padding-right: 0.75rem !important;
  }

  /* Better spacing for stacked elements */
  .space-y-8 {
    --tw-space-y-reverse: 0;
    margin-top: calc(1.5rem * calc(1 - var(--tw-space-y-reverse)));
    margin-bottom: calc(1.5rem * var(--tw-space-y-reverse));
  }
}

/* Tablet responsiveness */
@media (min-width: 641px) and (max-width: 1024px) {
  h1 {
    font-size: 2.5rem !important;
  }
  
  h2 {
    font-size: 2rem !important;
  }

  .container {
    padding-left: 1.5rem !important;
    padding-right: 1.5rem !important;
  }

  section {
    padding-top: -1rem !important;
    padding-bottom: -1rem !important;
  }
}

/* Mobile image responsiveness */
@media (max-width: 768px) {
  img {
    max-width: 100%;
    height: auto;
  }

  /* Video containers */
  .aspect-video {
    aspect-ratio: 16/9;
  }

  /* Grid to single column on small screens */
  .lg\:grid-cols-2 {
    grid-template-columns: 1fr !important;
  }

  /* Text alignment for mobile */
  .lg\:text-left {
    text-align: center !important;
  }

  /* Better blockquote on mobile */
  blockquote {
    padding-left: 1rem !important;
    font-size: 0.875rem !important;
  }

  /* Navbar stitch design adjustment for mobile */
  nav > div[style*="repeating-linear-gradient"] {
    left: 8px !important;
    right: 8px !important;
  }
}

/* Touch-friendly improvements */
@media (hover: none) and (pointer: coarse) {
  /* Remove hover effects that don't work well on touch */
  .group:hover {
    transform: none;
  }

  /* Ensure tap targets are large enough */
  .leather-stitch-box {
    padding: 6px;
  }

  /* Better touch feedback */
  button:active {
    transform: scale(0.98);
  }
}

/* Orientation-specific styles */
@media (max-width: 640px) and (orientation: landscape) {
  section {
    padding-top: 2rem !important;
    padding-bottom: 2rem !important;
  }

  .min-h-screen {
    min-height: auto !important;
  }
}

/* High DPI screen adjustments */
@media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
  .leather-stitch-box::before {
    border-width: 1px;
  }
}

/* Safe area insets for notched devices */
@supports (padding: max(0px)) {
  body {
    padding-left: max(0px, env(safe-area-inset-left));
    padding-right: max(0px, env(safe-area-inset-right));
  }

  nav {
    padding-left: max(1rem, env(safe-area-inset-left));
    padding-right: max(1rem, env(safe-area-inset-right));
  }

  footer {
    padding-bottom: max(2rem, env(safe-area-inset-bottom));
  }
}

/* Prevent horizontal scroll */
html, body {
  overflow-x: hidden;
  max-width: 100vw;
}

/* Better focus states for accessibility */
*:focus-visible {
  outline: 2px solid hsl(var(--saddle-tan));
  outline-offset: 2px;
}

/* Custom Zigzag Scrollbar - Luxury Leather Theme */
/* Webkit browsers (Chrome, Edge, Safari) */
::-webkit-scrollbar {
  width: 12px;
  height: 12px;
}

::-webkit-scrollbar-track {
  background: linear-gradient(180deg, #2C1810 0%, #1A0F0A 100%);
  border-left: 1px solid #3E2723;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, #D4A574 0%, #B8845B 50%, #A16D45 100%);
  border-radius: 2px;
  border: 2px solid #2C1810;
  position: relative;
  /* Zigzag pattern using a decorative background */
  background-image: 
    linear-gradient(135deg, transparent 25%, #C49464 25%, #C49464 50%, transparent 50%, transparent 75%, #C49464 75%, #C49464),
    linear-gradient(180deg, #D4A574 0%, #B8845B 50%, #A16D45 100%);
  background-size: 4px 4px, 100% 100%;
  background-repeat: repeat, no-repeat;
  box-shadow: 
    inset 0 1px 2px rgba(255, 255, 255, 0.2),
    0 0 8px rgba(212, 165, 116, 0.3);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, #E5B685 0%, #C9956C 50%, #B07E56 100%);
  background-image: 
    linear-gradient(135deg, transparent 25%, #D4A574 25%, #D4A574 50%, transparent 50%, transparent 75%, #D4A574 75%, #D4A574),
    linear-gradient(180deg, #E5B685 0%, #C9956C 50%, #B07E56 100%);
  background-size: 4px 4px, 100% 100%;
  background-repeat: repeat, no-repeat;
  box-shadow: 
    inset 0 1px 3px rgba(255, 255, 255, 0.3),
    0 0 12px rgba(212, 165, 116, 0.5),
    0 0 20px rgba(212, 165, 116, 0.3);
  transform: scale(1.05);
  transition: all 0.3s ease;
}

::-webkit-scrollbar-thumb:active {
  background: linear-gradient(180deg, #B8845B 0%, #A16D45 50%, #8A5A3A 100%);
  background-image: 
    linear-gradient(135deg, transparent 25%, #A16D45 25%, #A16D45 50%, transparent 50%, transparent 75%, #A16D45 75%, #A16D45),
    linear-gradient(180deg, #B8845B 0%, #A16D45 50%, #8A5A3A 100%);
  background-size: 4px 4px, 100% 100%;
  background-repeat: repeat, no-repeat;
  box-shadow: 
    inset 0 2px 4px rgba(0, 0, 0, 0.3),
    0 0 8px rgba(212, 165, 116, 0.4);
}

/* Scrollbar corner */
::-webkit-scrollbar-corner {
  background: #2C1810;
}

/* Firefox scrollbar */
* {
  scrollbar-width: thin;
  scrollbar-color: #D4A574 #2C1810;
}

/* Enhanced scrollbar with leather stitching effect */
@supports (scrollbar-width: thin) {
  html {
    scrollbar-width: thin;
    scrollbar-color: #D4A574 #2C1810;
  }
}

/* Smooth animations for reduced motion preference */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Interactive Globe Animations */
@keyframes float {
  0%, 100% {
    transform: translateY(0px);
  }
  50% {
    transform: translateY(-8px);
  }
}

@keyframes rotate-slow {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    filter: drop-shadow(0 0 20px rgba(34, 197, 94, 0.3));
  }
  50% {
    filter: drop-shadow(0 0 40px rgba(34, 197, 94, 0.6));
  }
}

.globe-interactive {
  animation: float 6s ease-in-out infinite;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
  position: relative;
}

.globe-interactive:hover {
  transform: scale(1.03) translateY(-5px);
  filter: drop-shadow(0 0 20px rgba(34, 197, 94, 0.3));
}

.globe-interactive::before {
  content: '';
  position: absolute;
  inset: -20px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(34, 197, 94, 0.1) 0%, transparent 70%);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
}

.globe-interactive:hover::before {
  opacity: 1;
  animation: pulse-glow 2s ease-in-out infinite;
}

.globe-rotate {
  animation: rotate-slow 30s linear infinite;
}

.globe-china {
  animation: float 6s ease-in-out infinite;
  filter: drop-shadow(0 0 25px rgba(239, 68, 68, 0.2));
}

.globe-china:hover {
  filter: drop-shadow(0 0 35px rgba(239, 68, 68, 0.3));
}

.globe-india {
  animation: float 6s ease-in-out infinite 0.5s;
  animation-fill-mode: both;
  filter: drop-shadow(0 0 25px rgba(34, 197, 94, 0.2));
}

.globe-india:hover {
  filter: drop-shadow(0 0 35px rgba(34, 197, 94, 0.3));
}
/* Mobile menu open - reduce brown padding */
body.mobile-menu-open main {
  padding-top: 3rem !important;
}

@media (min-width: 640px) {
  body.mobile-menu-open main {
    padding-top: 4rem !important;
  }
}

@media (min-width: 768px) {
  body.mobile-menu-open main {
    padding-top: 9rem !important;
  }
}
